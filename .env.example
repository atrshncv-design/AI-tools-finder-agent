# Context7 - Up-to-date documentation for LLMs
CONTEXT7_API_KEY=

# GitHub MCP Server
GITHUB_TOKEN=

# GitLab MCP Server (optional)
GITLAB_TOKEN=
GITLAB_API_URL=https://gitlab.com/api/v4

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/science_agent
POSTGRES_PASSWORD=postgres

# Domain (for nginx SSL)
DOMAIN=science-agent.ru

# CORS
CORS_ORIGIN=http://localhost:3000

# Redis
REDIS_URL=redis://localhost:6379

# AWS (for AWS MCP Server)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Cloudflare
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# Vercel
VERCEL_TOKEN=

# Netlify
NETLIFY_AUTH_TOKEN=

# Notion
NOTION_API_KEY=

# Linear
LINEAR_API_KEY=

# Sentry
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# PostHog
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com

# Brave Search
BRAVE_API_KEY=

# Session
SESSION_EXPIRY_HOURS=24

# Kimi OAuth
APP_ID=
APP_SECRET=
KIMI_AUTH_URL=
KIMI_OPEN_URL=
OWNER_UNION_ID=

# LM Studio
LM_STUDIO_URL=http://localhost:1234
LM_STUDIO_MODEL=google/gemma-4-e4b
LM_STUDIO_TIMEOUT_MS=60000
LM_STUDIO_MAX_INPUT_TOKENS=6000
LM_STUDIO_SUMMARY_MAX_TOKENS=1024
LM_STUDIO_DETAILED_MAX_TOKENS=2048
LM_STUDIO_TRANSLATION_MAX_TOKENS=4096
LM_STUDIO_RETRIES=3
LM_STUDIO_RETRY_DELAY_MS=5000
LM_STUDIO_CONCURRENCY=3

# GigaChat translation
GIGACHAT_API_KEY=
GIGACHAT_MODEL=GigaChat
GIGACHAT_TIMEOUT=120
GIGACHAT_RETRIES=3
GIGACHAT_CONCURRENCY=1
GIGACHAT_MAX_TOKENS=4096

# AI provider for summarization: "lmstudio" (default) or "gigachat"
SUMMARY_PROVIDER=lmstudio

# AI provider for translation: "gigachat" (default) or "lmstudio"
TRANSLATION_PROVIDER=lmstudio
GIGACHAT_SUMMARY_MAX_CHARS=12000
