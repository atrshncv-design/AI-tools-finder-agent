# Environment Variables
APP_ID=your_app_id
APP_SECRET=your_app_secret

# PostgreSQL Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/science_agent
POSTGRES_PASSWORD=postgres

# CORS
CORS_ORIGIN=http://localhost:3000

# Kimi Platform Auth
KIMI_AUTH_URL=https://kimi.platform/api/auth
KIMI_OPEN_URL=https://kimi.platform/api/open

# Owner
OWNER_UNION_ID=

# ─────────────────────────────────────────────────────────────────────────────
# Opencode Zen API (cloud AI for summarization and title translation)
# ─────────────────────────────────────────────────────────────────────────────
ZEN_BASE_URL=https://opencode.ai/zen/v1
# Key pool (comma-separated) — automatic rotation on quota/balance exhaustion.
# Legacy single-key ZEN_API_KEY is still supported as a fallback.
ZEN_API_KEYS=your_zen_key_1,your_zen_key_2
ZEN_KEY_COOLDOWN_MS=3600000
ZEN_MODEL=nemotron-3-ultra-free

# Request limits
ZEN_TIMEOUT_MS=120000
ZEN_MAX_INPUT_TOKENS=6000
ZEN_SUMMARY_MAX_TOKENS=1024
ZEN_DETAILED_MAX_TOKENS=2048
ZEN_TRANSLATION_MAX_TOKENS=4096

# Retry configuration
ZEN_RETRIES=3
ZEN_RETRY_DELAY_MS=2000
ZEN_CONCURRENCY=3

# Circuit breaker (stops calling Zen after N consecutive failures)
ZEN_CIRCUIT_BREAKER_THRESHOLD=5
ZEN_CIRCUIT_BREAKER_RESET_MS=60000

# Linear worker: interval between processing one article end-to-end (ms).
# Default 600000 = 10 minutes.
LINEAR_WORKER_INTERVAL_MS=600000

# Telegram digest (daily-digest.ts, cron 06:00)
# Comma-separated recipient chat IDs (owner + client). Legacy single
# TELEGRAM_CHAT_ID is supported as a fallback.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_IDS=
